__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Secrets & local data
# Ignore every config*.yaml (may hold real keys) EXCEPT the safe committed ones.
config/config*.yaml
!config/config.example.yaml
!config/config.ci.yaml
data_cache/
*.log
*.csv
!tests/**/*.csv

# Raw historical candle snapshots are LOCAL, regenerable data (~0.5 MB/symbol).
# They are NOT published: the public dashboard never reads them and no test
# depends on them. Reproducibility is anchored by the committed
# `*.manifest.json` SHA-256 hashes + `tools/download_history.py` (re-download,
# re-hash, compare). Track the small manifests; ignore the large raw payloads.
historical_data/**/*.raw.json
